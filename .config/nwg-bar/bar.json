[
  {
    "label": "Lock",
    "exec": "hyprlock",
    "icon": "/usr/share/icons/Papirus/16x16/actions/system-lock-screen.svg",
    "class": "blue"
  },
  {
    "label": "Reboot",
    "exec": "systemctl reboot",
    "icon": "/usr/share/icons/Papirus/16x16/symbolic/actions/system-reboot-symbolic.svg",
    "class": "yellow"
  },
  {
    "label": "Shutdown",
    "exec": "systemctl -i poweroff",
    "icon": "/usr/share/icons/Papirus/16x16/symbolic/actions/system-shutdown-symbolic.svg",
    "class": "red"
  }
  
]
